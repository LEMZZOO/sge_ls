n = int(input("Introduce el número de elementos de la secuencia de Fibonacci: "))

if n <= 0:
    print("La secuencia no tiene elementos.")
else:
    a, b = 1, 1
    
    print(a, end=" ")

    if n > 1:
        print(b, end=" ")

    for i in range(2, n):
        siguiente = a + b
        print(siguiente, end=" ")
        a, b = b, siguiente

    print()  
